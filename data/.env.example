# RehabiAPP — Data Pipeline environment template
# Copy to .env and fill real values. NEVER commit .env.
# All variables are read by Spring Boot via ${VAR:default} placeholders in application*.yml.

# --- Runtime ---
# HTTP port exposed by the service. Must be 8081 to avoid collision with the Core API (8080).
SERVER_PORT=8081

# Active Spring profile. Valid values: local | aws
SPRING_PROFILES_ACTIVE=local

# --- MongoDB ---
# Full MongoDB connection URI. In local dev, points to docker-compose or localhost.
# In AWS, this value is injected via CSI-mounted secret and MUST NOT be set in this file.
SPRING_DATA_MONGODB_URI=mongodb://localhost:27017/rehabiapp_telemetry

# --- CSFLE (Client-Side Field Level Encryption) ---
# Toggle for auto-encryption at the MongoClient level. Keep false until CSFLE is wired up.
CSFLE_ENABLED=false

# KMS provider: "local" for dev (file-based master key) or "aws" for AWS KMS via IRSA.
CSFLE_KMS_PROVIDER=local

# Filesystem path to the 96-byte local master key. Ignored when CSFLE_KMS_PROVIDER=aws.
CSFLE_MASTER_KEY_PATH=/mnt/secrets/csfle-master-key

# --- Internal service authentication ---
# Shared secret that the Core API presents when calling the data ingestion endpoints.
# Generate with: openssl rand -hex 32
API_INTERNAL_SHARED_KEY=change-me-local-only

# Cron expression (Spring 6-field format) for the analytics refresh job.
ANALYTICS_REFRESH_CRON=0 5 * * * *
