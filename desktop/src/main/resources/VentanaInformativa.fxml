<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.VBox?>


<VBox fx:id="vboxVentanaInformativa" alignment="CENTER" minHeight="300.0" minWidth="500.0" prefHeight="420.0" prefWidth="700.0" styleClass="root" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.javafx.Interface.controladorVentanaInformativa">
   <children>
      <ImageView fx:id="imgIconoInformacion" fitHeight="80.0" fitWidth="80.0" pickOnBounds="true" preserveRatio="true">
         <VBox.margin>
            <Insets top="20.0" />
         </VBox.margin>
      </ImageView>
      <Label fx:id="lblInformacion" textAlignment="CENTER" wrapText="true" maxWidth="600.0">
         <VBox.margin>
            <Insets bottom="30.0" left="50.0" right="50.0" top="30.0" />
         </VBox.margin>
      </Label>
      <Button fx:id="btnInformacion" mnemonicParsing="false" styleClass="button-primario" text="Aceptar">
         <VBox.margin>
            <Insets bottom="20.0" />
         </VBox.margin>
      </Button>
   </children>
</VBox>
